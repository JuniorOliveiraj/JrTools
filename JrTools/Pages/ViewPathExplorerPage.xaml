<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="JrTools.Pages.ViewPathExplorerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:dto="using:JrTools.Dto"
    xmlns:converters="using:JrTools.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Style>
    </Page.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- Row 0: Top panel - Project selector, Search button, Progress    -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Project selector and Search button -->
                <Grid Grid.Row="0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox
                        Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        PlaceholderText="Selecione um projeto..."
                        ItemsSource="{x:Bind ViewModel.Projetos, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.ProjetoSelecionado, Mode=TwoWay}"
                        DisplayMemberPath="Nome"/>

                    <Button
                        Grid.Column="1"
                        Content="Buscar"
                        Command="{x:Bind ViewModel.BuscarCommand}"
                        Style="{StaticResource AccentButtonStyle}"/>
                </Grid>

                <!-- Loading indicator -->
                <ProgressRing
                    Grid.Row="1"
                    IsActive="{x:Bind ViewModel.IsCarregando, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsCarregando, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                    HorizontalAlignment="Center"/>

                <!-- Error/Warning InfoBar -->
                <InfoBar
                    Grid.Row="2"
                    IsOpen="{x:Bind ViewModel.TemErro, Mode=OneWay}"
                    Severity="Error"
                    Message="{x:Bind ViewModel.MensagemErro, Mode=OneWay}"
                    IsClosable="True"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- Row 1: Two-column layout - Input and Results                    -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─────────────────────────────────────────────────────────── -->
            <!-- Left column: Input TextBox                                  -->
            <!-- ─────────────────────────────────────────────────────────── -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Text="Views (uma por linha):"
                        Style="{StaticResource LabelStyle}"/>

                    <TextBox
                        Grid.Row="1"
                        PlaceholderText="Digite os nomes das views...&#x0a;Exemplo:&#x0a;IWFuncionarios&#x0a;IWDepartamentos"
                        Text="{x:Bind ViewModel.TextoViews, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </Border>

            <!-- ─────────────────────────────────────────────────────────── -->
            <!-- Right column: Results ListView                              -->
            <!-- ─────────────────────────────────────────────────────────── -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Text="Resultados:"
                        Style="{StaticResource LabelStyle}"/>

                    <!-- Results ListView -->
                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.Resultados, Mode=OneWay}"
                        SelectionMode="None">

                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="8"/>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="dto:ViewResultadoItem">
                                <Border
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12"
                                    Margin="0,4">
                                    <Grid RowSpacing="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Header: View name and total count -->
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                Grid.Column="0"
                                                Text="{x:Bind NomeView}"
                                                FontWeight="SemiBold"
                                                FontSize="14"/>

                                            <TextBlock
                                                Grid.Column="1"
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                <Run Text="("/>
                                                <Run Text="{x:Bind TotalCaminhos}"/>
                                                <Run Text=" caminhos)"/>
                                            </TextBlock>
                                        </Grid>

                                        <!-- Paths list or "No paths found" message -->
                                        <StackPanel Grid.Row="1" Spacing="4">
                                            <!-- Show paths when available -->
                                            <ItemsControl
                                                ItemsSource="{x:Bind Caminhos}"
                                                Visibility="{x:Bind SemCaminhos, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="x:String">
                                                        <TextBlock
                                                            Text="{x:Bind}"
                                                            TextWrapping="Wrap"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            FontSize="12"
                                                            Margin="12,0,0,0"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Show "No paths found" when empty -->
                                            <TextBlock
                                                Text="Nenhum caminho encontrado"
                                                Visibility="{x:Bind SemCaminhos, Converter={StaticResource BoolToVisibilityConverter}}"
                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                FontStyle="Italic"
                                                FontSize="12"
                                                Margin="12,0,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Copy All button -->
                    <Button
                        Grid.Row="2"
                        Content="Copiar Tudo"
                        Command="{x:Bind ViewModel.CopiarTudoCommand}"
                        HorizontalAlignment="Right"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
