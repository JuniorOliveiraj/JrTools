<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="JrTools.Pages.ImportadorRelatoriosPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:dto="using:JrTools.Dto"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <DataTemplate x:Key="RelatorioItemTemplate" x:DataType="dto:RelatorioItem">
            <Grid Padding="4,6" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0"
                          IsChecked="{x:Bind Selecionado, Mode=TwoWay}"
                          VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{x:Bind Nome}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           ToolTipService.ToolTip="{x:Bind Caminho}"/>
                <Border Grid.Column="2"
                        CornerRadius="4"
                        Padding="8,2"
                        Background="{x:Bind StatusCor, Mode=OneWay}">
                    <TextBlock Text="{x:Bind StatusTexto, Mode=OneWay}"
                               FontSize="11"
                               Foreground="White"/>
                </Border>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40,30">
            <StackPanel Spacing="16">

                <!-- Cabeçalho -->
                <TextBlock Text="Importador de Relatórios RH"
                           FontSize="22"
                           FontWeight="Bold"/>

                <!-- Aviso de configuração inválida -->
                <InfoBar x:Name="InfoBarAviso"
                         IsOpen="False"
                         Severity="Warning"
                         IsClosable="False"/>

                <!-- Configurações da importação -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Configurações" FontWeight="SemiBold"/>
                        <Grid ColumnSpacing="12" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBox x:Name="TxtCaminhoRelatorios"
                                     Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                     Header="Diretório dos relatórios (.rpt)"
                                     PlaceholderText="Ex: D:\Benner\Relatorios\RH"
                                     TextChanged="TxtConfig_TextChanged"/>
                            <TextBox x:Name="TxtServidor"
                                     Grid.Row="1" Grid.Column="0"
                                     Header="Servidor"
                                     PlaceholderText="Ex: servidor.empresa.com.br"
                                     TextChanged="TxtConfig_TextChanged"/>
                            <TextBox x:Name="TxtSistema"
                                     Grid.Row="1" Grid.Column="1"
                                     Header="Sistema"
                                     PlaceholderText="rh"
                                     TextChanged="TxtConfig_TextChanged"/>
                        </Grid>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtUsuario"
                                     Header="Usuário"
                                     TextChanged="TxtConfig_TextChanged"/>
                            <PasswordBox x:Name="TxtSenha"
                                         Grid.Column="1"
                                         Header="Senha"
                                         PasswordChanged="TxtSenha_PasswordChanged"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Barra de busca e controles -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtBusca"
                                     PlaceholderText="Buscar relatório..."
                                     TextChanged="TxtBusca_TextChanged"/>
                            <Button x:Name="BtnAtualizar"
                                    Grid.Column="1"
                                    Content="Atualizar"
                                    Click="BtnAtualizar_Click"/>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="ChkSelecionarTodos"
                                      Content="Selecionar todos visíveis"
                                      Click="ChkSelecionarTodos_Click"/>
                            <TextBlock x:Name="TxtContador"
                                       Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontSize="12"/>
                            <Button x:Name="BtnImportarPendentes"
                                    Grid.Column="2"
                                    Content="Importar Pendentes"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Click="BtnImportarPendentes_Click"/>
                            <Button x:Name="BtnImportarSelecionados"
                                    Grid.Column="3"
                                    Content="Importar Selecionados"
                                    Click="BtnImportarSelecionados_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Lista de relatórios -->
                <Border Style="{StaticResource CardStyle}" MinHeight="200">
                    <Grid>
                        <ListView x:Name="ListaRelatorios"
                                  ItemTemplate="{StaticResource RelatorioItemTemplate}"
                                  SelectionMode="None"/>
                        <TextBlock x:Name="TxtListaVazia"
                                   Text="Nenhum relatório encontrado."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="Collapsed"/>
                        <ProgressRing x:Name="LoadingRing"
                                      IsActive="False"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Botão mostrar todos / recolher -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                    <Button x:Name="BtnMostrarTodos"
                            Content="Mostrar todos"
                            Visibility="Collapsed"
                            Click="BtnMostrarTodos_Click"/>
                    <Button x:Name="BtnRecolher"
                            Content="Mostrar menos"
                            Visibility="Collapsed"
                            Click="BtnRecolher_Click"/>
                </StackPanel>

                <!-- Progresso de importação -->
                <ProgressBar x:Name="ProgressoImportacao"
                             Visibility="Collapsed"
                             Minimum="0"
                             Maximum="100"
                             Value="0"/>

                <!-- Log de execução -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Log de execução"
                                   FontWeight="SemiBold"/>
                        <ScrollViewer x:Name="ScrollLog"
                                      MaxHeight="200"
                                      VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="TxtLog"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       IsTextSelectionEnabled="True"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
