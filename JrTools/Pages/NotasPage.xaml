<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="JrTools.Pages.NotasPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dto="using:JrTools.Dto"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- Card de nota na grid -->
        <Style x:Key="NotaCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <!-- Container GridViewItem sem margens -->
        <Style x:Key="CardItemContainerStyle" TargetType="GridViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>

        <!-- Botão secundário -->
        <Style x:Key="SecondaryBtnStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{ThemeResource SystemControlForegroundBaseLowBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <!-- Botão de perigo -->
        <Style x:Key="DangerBtnStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{ThemeResource SystemFillColorCriticalBrush}" />
            <Setter Property="Foreground" Value="{ThemeResource SystemFillColorCriticalBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
    </Page.Resources>

    <Grid>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!--  ESTADO 1 — Grid de Cards                                  -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid x:Name="CardsView" Padding="20,16,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <StackPanel HorizontalAlignment="Left">
                    <TextBlock Text="Notas" FontSize="26" FontWeight="Bold" />
                    <TextBlock x:Name="ContadorText" Text=""
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Margin="0,2,0,0" />
                </StackPanel>
                <Button HorizontalAlignment="Right"
                        Style="{ThemeResource AccentButtonStyle}"
                        Click="NovaNota_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE710;" FontSize="13" />
                        <TextBlock Text="Nova Nota" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Busca + Ordenação -->
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="BuscaInput" Grid.Column="0"
                         PlaceholderText="Buscar notas..."
                         TextChanged="Busca_TextChanged" />
                <ComboBox x:Name="OrdenarCombo" Grid.Column="1" Margin="10,0,0,0" Width="170"
                          SelectionChanged="Ordenar_SelectionChanged">
                    <ComboBoxItem Content="Mais recente" />
                    <ComboBoxItem Content="Mais antigo" />
                    <ComboBoxItem Content="A → Z" />
                    <ComboBoxItem Content="Z → A" />
                </ComboBox>
            </Grid>

            <!-- Chips de Tópicos -->
            <ScrollViewer Grid.Row="2"
                          HorizontalScrollMode="Enabled"
                          VerticalScrollMode="Disabled"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled"
                          Margin="0,0,0,14">
                <StackPanel x:Name="TopicosPanel" Orientation="Horizontal" Spacing="6" />
            </ScrollViewer>

            <!-- Grid de cards + empty state -->
            <Grid Grid.Row="3">
                <!-- Empty state -->
                <StackPanel x:Name="ListaEmptyState"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Spacing="12" Visibility="Collapsed">
                    <FontIcon Glyph="&#xE70B;" FontSize="48" HorizontalAlignment="Center"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock Text="Nenhuma nota ainda" FontSize="15" HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="Clique em + Nova Nota para começar" FontSize="13"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                </StackPanel>

                <!-- GridView responsivo -->
                <ScrollViewer>
                    <GridView x:Name="NotasGridView"
                              IsItemClickEnabled="True"
                              SelectionMode="None"
                              ItemClick="NotaCard_Click"
                              ItemContainerStyle="{StaticResource CardItemContainerStyle}">
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal"
                                               ItemWidth="256" ItemHeight="185"
                                               HorizontalAlignment="Left" />
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="dto:NotaDto">
                                <Border Style="{StaticResource NotaCardStyle}" Margin="6">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Badge tópico -->
                                        <Border Grid.Row="0" CornerRadius="4" Padding="6,2"
                                                Margin="0,0,0,10"
                                                HorizontalAlignment="Left"
                                                Background="{ThemeResource AccentAcrylicBackgroundFillColorDefaultBrush}">
                                            <TextBlock Text="{x:Bind Topico}" FontSize="11" />
                                        </Border>

                                        <!-- Título + Preview -->
                                        <StackPanel Grid.Row="1" Spacing="6">
                                            <TextBlock Text="{x:Bind Titulo}"
                                                       FontWeight="SemiBold" FontSize="14"
                                                       MaxLines="2" TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind PreviewConteudo}"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       MaxLines="3" TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <!-- Data -->
                                        <TextBlock Grid.Row="2"
                                                   Text="{x:Bind EditadoEmFormatado}"
                                                   FontSize="11" Margin="0,8,0,0"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!--  ESTADO 2 — Detalhe / Editor estilo Notion                 -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid x:Name="DetailView" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Toolbar de topo -->
            <Border Grid.Row="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Botão Voltar -->
                    <Button Grid.Column="0" Style="{StaticResource SecondaryBtnStyle}" Click="Voltar_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72B;" FontSize="13" />
                            <TextBlock Text="Notas" />
                        </StackPanel>
                    </Button>

                    <!-- Status de salvamento -->
                    <TextBlock x:Name="StatusSalvoText"
                               Grid.Column="1"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />

                    <!-- Ações: Preview + Excluir -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <ToggleButton x:Name="PreviewToggle"
                                      Checked="PreviewToggle_Checked"
                                      Unchecked="PreviewToggle_Unchecked">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE890;" FontSize="13" />
                                <TextBlock Text="Visualizar" />
                            </StackPanel>
                        </ToggleButton>
                        <Button Style="{StaticResource DangerBtnStyle}" Click="ExcluirDetail_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE74D;" FontSize="13" />
                                <TextBlock Text="Excluir" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Área de edição centralizada (estilo Notion) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="820"
                            HorizontalAlignment="Center"
                            Padding="20,24,20,24"
                            Spacing="12">

                    <!-- Card 1: Tópico + Título -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="20,16">
                        <StackPanel Spacing="10">
                            <!-- Tópico editável (chip) -->
                            <TextBox x:Name="DetailTopicoInput"
                                     PlaceholderText="Tópico"
                                     FontSize="12"
                                     Padding="10,4"
                                     CornerRadius="20"
                                     MinWidth="80"
                                     MaxWidth="220"
                                     HorizontalAlignment="Left"
                                     Background="{ThemeResource AccentAcrylicBackgroundFillColorDefaultBrush}"
                                     BorderThickness="0"
                                     TextChanged="DetailTopico_TextChanged" />

                            <!-- Título (grande, sem borda) -->
                            <TextBox x:Name="DetailTituloInput"
                                     FontSize="28"
                                     FontWeight="Bold"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     TextWrapping="Wrap"
                                     PlaceholderText="Sem título"
                                     TextChanged="DetailTitulo_TextChanged" />
                        </StackPanel>
                    </Border>

                    <!-- Card 2: Conteúdo Markdown -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="20,16"
                            MinHeight="400">
                        <!-- Editor e preview se sobrepõem dentro do card -->
                        <Grid>
                            <TextBox x:Name="DetailConteudoInput"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     MinHeight="360"
                                     PlaceholderText="Comece a escrever... (suporta Markdown)"
                                     TextChanged="DetailConteudo_TextChanged" />

                            <!-- Preview WebView2 (criado via código ao alternar) -->
                            <Grid x:Name="PreviewContainer" Visibility="Collapsed" MinHeight="360" />
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

    </Grid>
</Page>
