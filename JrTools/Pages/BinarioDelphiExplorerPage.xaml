<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="JrTools.Pages.BinarioDelphiExplorerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:dto="using:JrTools.Dto"
    xmlns:converters="using:JrTools.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Style>
    </Page.Resources>

    <!-- Main two-row layout -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- Row 0: Filters + List                                           -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="12,12,12,6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Filters bar -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Filter by name -->
                    <TextBox
                        x:Name="FiltroNomeTextBox"
                        Grid.Column="0"
                        PlaceholderText="Filtrar por nome..."
                        Text="{x:Bind ViewModel.TextoFiltroNome, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Filter by extension -->
                    <ComboBox
                        x:Name="ExtensaoComboBox"
                        Grid.Column="1"
                        MinWidth="120"
                        PlaceholderText="Extensão"
                        SelectionChanged="ExtensaoComboBox_SelectionChanged"/>

                    <!-- Refresh button -->
                    <Button
                        Grid.Column="2"
                        Content="Atualizar"
                        Command="{x:Bind ViewModel.AtualizarIndiceCommand}"/>

                    <!-- Counter -->
                    <TextBlock
                        Grid.Column="3"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        FontSize="12">
                        <Run Text="{x:Bind ViewModel.TotalFiltrado, Mode=OneWay}"/>
                        <Run Text=" de "/>
                        <Run Text="{x:Bind ViewModel.TotalNoIndice, Mode=OneWay}"/>
                        <Run Text=" binários"/>
                    </TextBlock>

                    <!-- Directory label -->
                    <TextBlock
                        Grid.Column="4"
                        VerticalAlignment="Center"
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Text="{x:Bind ViewModel.DiretorioAtual, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis"
                        MaxWidth="200"
                        ToolTipService.ToolTip="{x:Bind ViewModel.DiretorioAtual, Mode=OneWay}"/>
                </Grid>
            </Border>

            <!-- Loading indicator -->
            <ProgressRing
                Grid.Row="1"
                IsActive="{x:Bind ViewModel.CarregandoIndice, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.CarregandoIndice, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                HorizontalAlignment="Center"
                Margin="0,8"/>

            <!-- Error bar -->
            <InfoBar
                Grid.Row="2"
                IsOpen="{x:Bind ViewModel.TemErro, Mode=OneWay}"
                Severity="Error"
                Message="{x:Bind ViewModel.MensagemErro, Mode=OneWay}"
                IsClosable="True"
                Margin="0,0,0,4"/>

            <!-- Empty state message -->
            <TextBlock
                Grid.Row="3"
                Text="Nenhum binário encontrado para o filtro aplicado."
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Visibility="{x:Bind ViewModel.ListaVaziaComIndice, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                Margin="0,8"/>

            <!-- List header -->
            <Border Grid.Row="4" BorderThickness="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Column headers -->
                    <Grid Grid.Row="0" Padding="12,6" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Nome" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Grid.Column="1" Text="Extensão" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Grid.Column="2" Text="Tamanho" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Grid.Column="3" Text="Data de Modificação" Style="{StaticResource LabelStyle}"/>
                    </Grid>

                    <!-- Binaries list -->
                    <ListView
                        x:Name="BinariosListView"
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.ItensFiltrados, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.ItemSelecionado, Mode=TwoWay}"
                        SelectionMode="Single">

                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="12,4"/>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="dto:BinarioDelphiItem">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Text="{x:Bind Nome}"
                                        TextTrimming="CharacterEllipsis"
                                        ToolTipService.ToolTip="{x:Bind Nome}"/>
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{x:Bind Extensao}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock
                                        Grid.Column="2"
                                        Text="{x:Bind TamanhoFormatado}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock
                                        Grid.Column="3"
                                        Text="{x:Bind DataModificacaoFormatada}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- Row 1: Details panel                                            -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="12,6,12,12">
            <Grid>
                <!-- Loading indicator for details -->
                <ProgressRing
                    IsActive="{x:Bind ViewModel.CarregandoDetalhe, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.CarregandoDetalhe, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>

                <!-- Details content -->
                <StackPanel
                    Visibility="{x:Bind ViewModel.DetalheDisponivel, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                    Spacing="6">

                    <TextBlock
                        Text="Detalhes do arquivo selecionado"
                        FontWeight="SemiBold"
                        FontSize="13"
                        Margin="0,0,0,4"/>

                    <!-- Path -->
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Caminho:" Style="{StaticResource LabelStyle}" MinWidth="80"/>
                        <TextBlock
                            Grid.Column="1"
                            Text="{x:Bind ViewModel.DetalheAtual.CaminhoCompleto, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis"
                            IsTextSelectionEnabled="True"
                            ToolTipService.ToolTip="{x:Bind ViewModel.DetalheAtual.CaminhoCompleto, Mode=OneWay}"/>
                    </Grid>

                    <!-- Version -->
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Versão:" Style="{StaticResource LabelStyle}" MinWidth="80"/>
                        <TextBlock
                            Grid.Column="1"
                            Text="{x:Bind ViewModel.DetalheAtual.VersaoArquivo, Mode=OneWay}"
                            IsTextSelectionEnabled="True"/>
                    </Grid>

                    <!-- Product version -->
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Produto:" Style="{StaticResource LabelStyle}" MinWidth="80"/>
                        <TextBlock
                            Grid.Column="1"
                            Text="{x:Bind ViewModel.DetalheAtual.VersaoProduto, Mode=OneWay}"
                            IsTextSelectionEnabled="True"/>
                    </Grid>

                    <!-- Description -->
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Descrição:" Style="{StaticResource LabelStyle}" MinWidth="80"/>
                        <TextBlock
                            Grid.Column="1"
                            Text="{x:Bind ViewModel.DetalheAtual.DescricaoArquivo, Mode=OneWay}"
                            IsTextSelectionEnabled="True"/>
                    </Grid>

                    <!-- Company -->
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Empresa:" Style="{StaticResource LabelStyle}" MinWidth="80"/>
                        <TextBlock
                            Grid.Column="1"
                            Text="{x:Bind ViewModel.DetalheAtual.Empresa, Mode=OneWay}"
                            IsTextSelectionEnabled="True"/>
                    </Grid>

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                        <Button
                            Content="Abrir no Explorer"
                            Command="{x:Bind ViewModel.AbrirNoExplorerCommand}"/>
                        <Button
                            Content="Copiar Caminho"
                            Command="{x:Bind ViewModel.CopiarCaminhoCommand}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Placeholder when nothing is selected -->
                <TextBlock
                    Text="Selecione um binário para ver os detalhes."
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Visibility="{x:Bind ViewModel.DetalheDisponivel, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</Page>
